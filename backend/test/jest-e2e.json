{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testMatch": ["test/**/*.e2e-spec.ts"],
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "modulePathIgnorePatterns": ["<rootDir>/dist/"],
  "setupFilesAfterEnv": ["<rootDir>/test/setup-e2e.ts"]
}
